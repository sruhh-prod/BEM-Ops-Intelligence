# BEM Operations Intelligence — Environment Variables
# Copy to .env and fill in your values. Never commit .env to source control.

# Hostaway API
HOSTAWAY_CLIENT_ID=
HOSTAWAY_CLIENT_SECRET=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Operational settings
# How many days back/forward to fetch reservations
RESERVATION_WINDOW_DAYS_BACK=30
RESERVATION_WINDOW_DAYS_FORWARD=90

# Risk engine thresholds (hours)
STALE_TASK_THRESHOLD_HOURS=48
AT_RISK_ARRIVAL_WINDOW_HOURS=72
EXPIRING_LICENSE_WARNING_DAYS=90
